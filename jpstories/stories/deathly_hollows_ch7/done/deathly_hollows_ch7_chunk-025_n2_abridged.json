                           "id":  "p-073",
                           "sentences":  [
                                             {
                                                 "id":  "s-172",
                                                 "english":  "“I was there it was right there on the wall of his office during all our talks last year!"
                                             },
                                             {
                                                 "id":  "s-173",
                                                 "english":  "If he wanted me to have it, why didn’t he just give it to me then?"
                                             }
                                         ]
                       },
                       {
                           "id":  "p-074",
                           "sentences":  [
                                             {
                                                 "id":  "s-174",
                                                 "english":  "He felt as though he were sitting in an examination with a question he ought to have been able to answer in front of him, his brain slow and unresponsive."
                                             },
                                             {
                                                 "id":  "s-175",
                                                 "english":  "Was there something he had missed in the long talks with Dumbledore last year?"
                                             },
                                             {
                                                 "id":  "s-176",
                                                 "english":  "Ought he to know what it all meant?"
                                             },
                                             {
                                                 "id":  "s-177",
                                                 "english":  "Had Dumbledore expected him to understand?"
                                             }
                                         ]
                       },
                       {
                           "id":  "p-075",
                           "sentences":  [
                                             {
                                                 "id":  "s-178",
                                                 "english":  "“And as for this book” said Hermione, “The Tales of Beedle the Bard ."
                                             },
                                             {
                                                 "id":  "s-179",
                                                 "english":  "."
                                             },
                                             {
                                                 "id":  "s-180",
                                                 "english":  "."
                                             },
                                             {
                                                 "id":  "s-181",
                                                 "english":  "I’ve never even heard of them.”"
                                             }
                                         ]
                       }
                   ],
    "translations":  {
                         "s-172":  "「去年、僕は何度も校長室にいた。あの剣はずっと壁に掛かっていたんだ！」",
                         "s-173":  "「僕に渡したかったなら、なぜあの時くれなかったんだ？」",
                         "s-174":  "ハリーは、答えられるはずの試験問題を前にして、頭が鈍く動かないような気分だった。",
                         "s-175":  "去年のダンブルドアとの長い話で、何か聞き落としたのだろうか。",
                         "s-176":  "本当は意味を理解しているべきだったのか。",
                         "s-177":  "ダンブルドアは、彼が分かると期待していたのか。",
                         "s-178":  "「それに、この本だけど」とハーマイオニーは言った。「『吟遊詩人ビードルの物語』",
                         "s-179":  "…",
                         "s-180":  "…",
                         "s-181":  "こんな話、聞いたこともないわ」"
                     }
}
