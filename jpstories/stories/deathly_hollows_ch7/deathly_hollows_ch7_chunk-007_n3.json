    "paragraphs":  [
                       {
                           "id":  "p-019",
                           "sentences":  [
                                             {
                                                 "id":  "s-037",
                                                 "english":  "“—Dumbledore wanted to give me the sword?” said Harry, struggling to keep his temper."
                                             },
                                             {
                                                 "id":  "s-038",
                                                 "english":  "“Maybe he thought it would look nice on my wall.”"
                                             }
                                         ]
                       },
                       {
                           "id":  "p-020",
                           "sentences":  [
                                             {
                                                 "id":  "s-039",
                                                 "english":  "“This is not a joke, Potter!” growled Scrimgeour."
                                             },
                                             {
                                                 "id":  "s-040",
                                                 "english":  "“Was it because Dumbledore believed that only the sword of Godric Gryffindor could defeat the Heir of Slytherin?"
                                             },
                                             {
                                                 "id":  "s-041",
                                                 "english":  "Did he wish to give you that sword, Potter, because he believed, as do many, that you are the one destined to destroy He-Who-Must-Not-Be-Named?”"
                                             }
                                         ]
                       },
                       {
                           "id":  "p-021",
                           "sentences":  [
                                             {
                                                 "id":  "s-042",
                                                 "english":  "“Interesting theory,” said Harry."
                                             },
                                             {
                                                 "id":  "s-043",
                                                 "english":  "“Has anyone ever tried sticking a sword in Voldemort?"
                                             },
                                             {
                                                 "id":  "s-044",
                                                 "english":  "Maybe the Ministry should put some people onto that, instead of wasting their time stripping down Deluminators or covering up breakouts from Azkaban."
                                             },
                                             {
                                                 "id":  "s-045",
                                                 "english":  "So this is what you’ve been doing, Minister, shut up in your office, trying to break open a Snitch?"
                                             },
                                             {
                                                 "id":  "s-046",
                                                 "english":  "People are dying—I was nearly one of them— Voldemort chased me across three countries, he killed Mad-Eye Moody, but there’s been no word about any of that from the Ministry, has there?"
                                             },
                                             {
                                                 "id":  "s-047",
                                                 "english":  "And you still expect us to cooperate with you!”"
                                             }
                                         ]
                       }
                   ],
