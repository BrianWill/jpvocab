                           "id":  "p-035",
                           "sentences":  [
                                             {
                                                 "id":  "s-081",
                                                 "english":  "“What did he want?” Mr."
                                             },
                                             {
                                                 "id":  "s-082",
                                                 "english":  "Weasley asked, looking around at Harry, Ron, and Hermione as Mrs."
                                             },
                                             {
                                                 "id":  "s-083",
                                                 "english":  "Weasley came hurrying back to them."
                                             }
                                         ]
                       },
                       {
                           "id":  "p-036",
                           "sentences":  [
                                             {
                                                 "id":  "s-084",
                                                 "english":  "“To give us what Dumbledore left us,” said Harry."
                                             },
                                             {
                                                 "id":  "s-085",
                                                 "english":  "“They’ve only just released the contents of his will.”"
                                             }
                                         ]
                       }
                   ],
    "translations":  {
                         "s-077":  "彼はそれ以上何も言わずに背を向け、足を引きずって部屋を出ていった。",
                         "s-078":  "ミセス",
                         "s-079":  "ウィーズリーは急いで彼の後を追い、ハリーには彼女が裏口で止まる音が聞こえた。",
                         "s-080":  "一分ほどして、彼女は「行ってしまったわ！」と呼んだ。",
                         "s-081":  "「彼は何をしに来たんだ？」とミスター",
                         "s-082":  "ウィーズリーは、ミセス",
                         "s-083":  "ウィーズリーが急いで戻ってくる中で、ハリー、ロン、ハーマイオニーを見回してたずねた。",
                         "s-084":  "「ダンブルドアが僕たちに残した物を渡しに来たんです」とハリーは言った。",
                         "s-085":  "「遺言の中身が、たった今やっと公開されたんです」"
