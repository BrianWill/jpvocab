                           "id":  "p-035",
                           "sentences":  [
                                             {
                                                 "id":  "s-081",
                                                 "english":  "“What did he want?” Mr."
                                             },
                                             {
                                                 "id":  "s-082",
                                                 "english":  "Weasley asked, looking around at Harry, Ron, and Hermione as Mrs."
                                             },
                                             {
                                                 "id":  "s-083",
                                                 "english":  "Weasley came hurrying back to them."
                                             }
                                         ]
                       },
                       {
                           "id":  "p-036",
                           "sentences":  [
                                             {
                                                 "id":  "s-084",
                                                 "english":  "“To give us what Dumbledore left us,” said Harry."
                                             },
                                             {
                                                 "id":  "s-085",
                                                 "english":  "“They’ve only just released the contents of his will.”"
                                             }
                                         ]
                       }
                   ],
    "translations":  {
                         "s-077":  "彼はそれ以上何も言わずに背を向け、足を引きずって部屋を出ていった。",
                         "s-078":  "ウィーズリー夫人は",
                         "s-079":  "急いでその後を追い、ハリーには彼女が裏口のところで立ち止まる音が聞こえた。",
                         "s-080":  "一分ほどして、彼女が「行ったわ！」と呼んだ。",
                         "s-081":  "「何の用だったんだ？」とウィーズリー氏は、",
                         "s-082":  "戻ってきたウィーズリー夫人を迎えながら、ハリー、ロン、ハーマイオニーを見回して尋ねた。",
                         "s-083":  "ウィーズリー夫人は急ぎ足で皆のもとへ戻ってきた。",
                         "s-084":  "「ダンブルドアが僕たちに残したものを渡しに来たんです」とハリーは言った。",
                         "s-085":  "「遺言の内容が、たった今ようやく公開されたんです」"
