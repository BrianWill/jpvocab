    "paragraphs":  [
                       {
                           "id":  "p-004",
                           "sentences":  [
                                             {
                                                 "id":  "s-005",
                                                 "english":  "It carries an enchantment by which it can identify the first human to lay hands upon it, in the case of disputed capture."
                                             },
                                             {
                                                 "id":  "s-006",
                                                 "english":  "This Snitch”—he held up the tiny golden ball—“will remember your touch, Potter."
                                             },
                                             {
                                                 "id":  "s-007",
                                                 "english":  "It occurs to me that Dumbledore, who had prodigious magical skill, whatever his other faults, might have enchanted this Snitch so that it will open only for you.”"
                                             }
                                         ]
                       },
                       {
                           "id":  "p-005",
                           "sentences":  [
                                             {
                                                 "id":  "s-008",
                                                 "english":  "Harry’s heart was beating rather fast."
                                             },
                                             {
                                                 "id":  "s-009",
                                                 "english":  "He was sure that Scrimgeour was right."
                                             },
                                             {
                                                 "id":  "s-010",
                                                 "english":  "How could he avoid taking the Snitch with his bare hand in front of the Minister?"
                                             }
                                         ]
                       },
                       {
                           "id":  "p-006",
                           "sentences":  [
                                             {
                                                 "id":  "s-011",
                                                 "english":  "“You don’t say anything,” said Scrimgeour."
                                             },
                                             {
                                                 "id":  "s-012",
                                                 "english":  "“Perhaps you already know what the Snitch contains?”"
                                             }
                                         ]
                       }
                   ],
    "translations":  {
                         "s-005":  "争いになった時のため、最初に触れた人間を見分ける魔法がかかっている。",
                         "s-006":  "彼は小さな金の球を掲げ、「このスニッチは君の手を覚えている、ポッター」と言った。",
                         "s-007":  "「ダンブルドアほどの魔法使いなら、欠点はあっても、このスニッチを君だけに開くよう細工したかもしれない。」",
                         "s-008":  "ハリーの心臓は少し速く打っていた。",
                         "s-009":  "スクリムジョールの考えは正しいと感じた。",
                         "s-010":  "大臣の前で、どうすれば素手で受け取らずに済むだろう。",
                         "s-011":  "「黙っているな」とスクリムジョールは言った。",
                         "s-012":  "「中に何が入っているか、もう知っているのか？」"
                     }
}
