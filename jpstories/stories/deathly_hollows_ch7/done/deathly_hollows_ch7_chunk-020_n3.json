                                             {
                                                 "id":  "s-139",
                                                 "english":  "“The Snitch I caught in my first ever Quidditch match?” said Harry."
                                             },
                                             {
                                                 "id":  "s-140",
                                                 "english":  "“Don’t you remember?”"
                                             }
                                         ]
                       },
                       {
                           "id":  "p-059",
                           "sentences":  [
                                             {
                                                 "id":  "s-141",
                                                 "english":  "Hermione looked simply bemused."
                                             },
                                             {
                                                 "id":  "s-142",
                                                 "english":  "Ron, however, gasped, pointing frantically from Harry to the Snitch and back again until he found his voice."
                                             }
                                         ]
                       },
                       {
                           "id":  "p-060",
                           "sentences":  [
                                             {
                                                 "id":  "s-143",
                                                 "english":  "“That was the one you nearly swallowed!”"
                                             }
                                         ]
                       }
                   ],
    "translations":  {
                         "s-139":  "「僕が初めてのクィディッチの試合で捕まえたスニッチだよ？」とハリーは言った。",
                         "s-140":  "「覚えていないの？」",
                         "s-141":  "ハーマイオニーはただ困ったような顔をした。",
                         "s-142":  "しかしロンははっと息をのみ、声が出るまで、ハリーからスニッチへ、またスニッチからハリーへとあわてて指を向けた。",
                         "s-143":  "「それ、おまえがもう少しで飲み込みそうになったやつだ！」"
                     }
}
